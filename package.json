		"@types/chai": "^4.2.21",
		"@types/lodash-es": "^4.17.4",
		"@types/mocha": "^8.2.3",
		"@typescript-eslint/parser": "^4.28.4",
		"autoprefixer": "^10.3.1",
		"babel-loader": "^8.2.2",
		"chai": "^4.3.4",
		"clean-webpack-plugin": "^3.0.0",
		"clsx": "^1.1.1",
		"concurrently": "^6.2.0",
		"eslint-config-xo-react": "^0.25.0",
		"gulp": "^4.0.2",
		"gulp-csso": "^4.0.1",
		"gulp-dart-sass": "^1.0.2",
		"gulp-htmlmin": "^5.0.1",
		"gulp-if": "^3.0.0",
		"gulp-postcss": "^9.0.0",
		"gulp-rename": "^2.0.0",
		"gulp-sourcemaps": "^3.0.0",
		"gulp-svgmin": "^4.0.1",
		"hex-rgb": "^5.0.0",
		"lazypipe": "^1.0.2",
		"mocha": "^9.0.2",
		"prettier": "^2.3.2",
		"rgb-hex": "^4.0.0",
		"sass": "^1.35.2",
		"serve": "^12.0.0",
		"terser-webpack-plugin": "^5.1.4",
		"ts-loader": "^9.2.3",
		"ts-node": "^10.1.0",
		"type-fest": "^1.2.2",
		"typescript": "^4.3.5",
		"webpack": "^5.45.1",
		"webpack-cli": "^4.7.2",
		"webpack-glob-entry": "^2.1.1",
		"xo": "^0.42.0"
	},
	"license": "MIT",
	"name": "melusc.github.io",
	"prettier": {
		"arrowParens": "avoid",
		"bracketSpacing": false,
		"singleQuote": true,
		"trailingComma": "all",
		"useTabs": true
	},
	"private": true,
	"scripts": {
		"build": "npm run test && npm run build-no-test",
		"build-no-test": "npm run webpack:b && npm run gulp:b",
		"gulp:b": "gulp build",
		"gulp:w": "gulp start",
		"lint": "npm run prettier && xo --fix",
		"mocha-tests": "mocha test/**/*.test.js && mocha -r ts-node/register test/**/*.test.ts",
		"prettier": "prettier -w \"{src,test}/**\" \"!src/**/*.svg\"",
		"sass": "sass src:src",
		"sass:w": "sass src:src --watch",
		"serve": "serve docs",
		"start": "concurrently npm:webpack:w npm:gulp:w npm:serve",
		"test": "npm run lint && npm run mocha-tests",
		"webpack:b": "webpack -c webpack-config.js --env=production",
		"webpack:w": "webpack -c webpack-config.js -w"
	},
	"sideEffects": false,
	"version": "1.0.0"
}
